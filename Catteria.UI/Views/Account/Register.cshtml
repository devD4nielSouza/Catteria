
@model RegisterDto

@{
    ViewData["Title"] = "Registrar - Catteria";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Register"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
</head>
<body>

    <div class="container-fluid login-container">
        <div class="row h-100">

            <div class="col-md-6 d-none d-md-block login-image"></div>

            <div class="col-md-6 col-12 login-form">
                <div class="form-box">

                    <img class="LoginImg" src="/Imagens/LogoLogin.png" alt="Logo">
                    <h2 class="mb-4 text-center">Registrar-se</h2>

                    @* RESUMO: Bloco de Validação (ModelState)
                        - O que faz: Checa se o C# encontrou algum erro ao tentar processar o cadastro.
                        - Como funciona: Se houver erros (como e-mail repetido ou senha fraca), ele abre um 
                          alerta vermelho na tela e lista cada um dos problemas para o usuário corrigir.
                    *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2" role="alert">
                            <small>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span>@error.ErrorMessage</span>
                                    <br />
                                }
                            </small>
                        </div>
                    }

                    @* RESUMO: Configuração do Formulário (Form)
                        - asp-controller="Account": Diz que as informações vão para o arquivo 'AccountController' no C#.
                        - asp-action="Register": Diz para o C# executar especificamente a função 'Register' (Registrar).
                        - method="post": Envia os dados escondidos (em pacote fechado), protegendo a senha do usuário.
                    *@
                    <form asp-controller="Account" asp-action="Register" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label">Nome</label>
                            @* asp-for="Name": Liga este campo de texto diretamente à propriedade 'Name' no banco/C# *@
                            <input id="forms1" asp-for="Name" type="text" class="form-control" placeholder="Digite seu nome completo" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Telefone</label>
                            @* asp-for="Telephone": Envia o número digitado para o campo 'Telephone' no banco/C# *@
                            <input asp-for="Telephone" type="tel" class="form-control" placeholder="(00) 00000-0000" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            @* asp-for="Email": Envia o e-mail digitado para o campo 'Email' no banco/C# *@
                            <input asp-for="Email" type="email" class="form-control" placeholder="Digite seu e-mail" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Endereço</label>
                            @* asp-for="Address": Envia o endereço digitado para o campo 'Address' no banco/C# *@
                            <input asp-for="Address" type="text" class="form-control" placeholder="Digite seu endereço completo" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Senha</label>
                            @* asp-for="Password": Envia a senha criada de forma segura para o campo 'Password' no C# *@
                            <input id="forms2" asp-for="Password" type="password" class="form-control" placeholder="Crie uma senha" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Confirmar Senha</label>
                            @* asp-for="ConfirmPassword": Envia o texto para o C# comparar se está igualzinho à primeira senha *@
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirme sua senha" required />
                        </div>

                        <div class="d-grid">
                            @* type="submit": É o gatilho que dispara o envio de todas as informações do formulário para o banco *@
                            <button type="submit" class="btn btn-primary">
                                Cadastrar
                            </button>
                        </div>
              
                        <div class="mt-3 text-center">
                            <span style="color: #4e4e4e; font-size: 14px;">Já tem uma conta? </span>
                            @* RESUMO: Link Inteligente (Tag Helper)
                                - Em vez de usar um link manual, as tags asp-controller e asp-action geram 
                                  automaticamente a rota certa para redirecionar o usuário para a tela de Login.
                            *@
                            <a asp-controller="Account" asp-action="Login" style="color: #4e4e4e; font-weight: bold; text-decoration: none; font-size: 14px;">Faça login aqui</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</body>
</html>
