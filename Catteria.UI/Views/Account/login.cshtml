@model LoginDto
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-Br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Login"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
</head>
<body>

    <div class="container-fluid login-container">
        <div class="row h-100">

            <div class="col-md-6 d-none d-md-block login-image"></div>

            <div class="col-md-6 col-12 login-form">
                <div class="form-box">
          
                    <img class="LoginImg" src="/Imagens/LogoLogin.png" alt="Logo" />
                    <h2 class="mb-4 text-center">Entrar</h2>

                    @* RESUMO: Painel de Mensagens de Erro (ModelState)
                        - O que faz: Analisa se o C# encontrou problemas ao verificar suas credenciais.
                        - Como funciona: Caso a senha esteja errada ou o e-mail não exista, este bloco 
                          ganha vida, exibindo uma caixa vermelha com os erros exatos retornados pelo servidor.
                    *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2" role="alert">
                            <small>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span>@error.ErrorMessage</span>
                                    <br />
                                }
                            </small>
                        </div>
                    }

                    @* RESUMO: Estrutura do Formulário de Envio (Form)
                        - asp-controller="Account": Envia o pacote de dados para o controlador de contas ('AccountController').
                        - asp-action="Login": Aciona especificamente a função encarregada de autenticar o acesso ('Login').
                        - method="post": Envia tudo de forma oculta e criptografada pelo corpo da requisição, protegendo a senha.
                    *@
                    <form asp-controller="Account" asp-action="Login" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            @* asp-for="Email": Cria o vínculo direto entre este campo de texto e a propriedade 'Email' do seu LoginDto no C# *@
                            <input id="forms1" asp-for="Email" type="email" class="form-control" placeholder="Digite seu e-mail" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Senha</label>
                            @* asp-for="Password": Conecta os caracteres ocultos digitados aqui à propriedade de validação 'Password' do banco *@
                            <input id="forms2" asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                        </div>

                        <div class="d-grid">
                            @* type="submit": Funciona como o interruptor que dispara o formulário completo em direção à sua infraestrutura *@
                            <button type="submit" class="btn btn-primary">
                                Login
                            </button>
                        </div>

                        <div class="mt-3 text-center">
                            <span style="color: #4e4e4e; font-size: 14px;">Não tem uma conta? </span>
                            @* RESUMO: Link Dinâmico (Tag Helper)
                                - Substitui caminhos manuais complexos. Utiliza o ecossistema do ASP.NET para descobrir
                                  sozinho a rota correta e guiar o usuário de forma limpa até a tela de Registro.
                            *@
                            <a asp-controller="Account" asp-action="Register" style="color: #4e4e4e; font-weight: bold; text-decoration: none; font-size: 14px;">Registre-se aqui</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div></body>
</html>