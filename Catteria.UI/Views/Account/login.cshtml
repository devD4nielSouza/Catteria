@model LoginDto
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-Br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>

    <div class="container-fluid login-container">
        <div class="row h-100">

            <div class="col-md-6 d-none d-md-block login-image"></div>

            <div class="col-md-6 col-12 login-form">
                <div class="form-box">
          
                    <img class="LoginImg" src="../imgs/Loren-y (4).png" alt="">
                    <h2 class="mb-4 text-center">Entrar</h2>

                    @* Exibe erros de validação *@
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2" role="alert">
                            <small>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <span>@error.ErrorMessage</span>
                    
                                    <br />
                                }
                            </small>
                        </div>
                    }

                    <form>
                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <input id="forms1" type="email" class="form-control" placeholder="Digite seu e-mail">
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Senha</label>
                            <input id="forms2" type="password" class="form-control">
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="••••••••" required />

                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">
                                Login
                            </button>
                        </div>

                        <div class="mt-3 text-center">
                            <span style="color: #4e4e4e; font-size: 14px;">Não tem uma conta? </span>
                            <a href="#" style="color: #4e4e4e; font-weight: bold; text-decoration: none; font-size: 14px;">Registre-se aqui</a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>

</body>
</html>