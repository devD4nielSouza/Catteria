@* Detalhes do Game — Design Stitch *@
@model ProductDetailsViewModel
@{
    ViewData["Title"] = Model.Product.Name;
}

@* Header com background azul *@
<section class="game-detail-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-4 mb-lg-0">
                <div class="game-detail-cover">
                    @if (!string.IsNullOrEmpty(Model.Product.CoverImageUrl))
                    {
                        <img src="@Model.Product.CoverImageUrl" alt="@Model.Product.Name" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center" style="height: 350px; background: var(--surface-container-high);">
                            <i class="bi bi-controller" style="font-size: 5rem; color: var(--on-surface-variant);"></i>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-7">
                <div class="game-detail-info">
                    <div class="game-meta">
                        <span><i class="bi bi-tag-fill"></i> @Model.Product.CategoryId</span>
                        <span><i class="bi bi-calendar3"></i> @Model.Product.CreatedAt</span>
                        @if (Model.Product.IsFeatured)
                        {
                            <span class="highlight">
                                <i class="bi bi-star-fill"></i> Destaque
                            </span>
                        }
                    </div>
                    <h1>@Model.Product.Name</h1>
                    <p class="mt-3" style="font-size: 1.1rem; opacity: 0.9;">
                        @Model.Product.Description
                    </p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-light mt-3">
                        <i class="bi bi-arrow-left"></i> Voltar ao Catálogo
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>