@model Catteria.Application.ViewModels.ProductListViewModel
@{
    ViewData["Title"] = "Cardápio";
    var searchTerm = Context.Request.Query["search"].ToString();
}

<div class="section-title-bar bg-white py-3 border-bottom text-center fw-bold fs-4" style="color: #4c78b2;">
    Cardápio Completo
</div>

<div class="products-section my-5">
    <div class="container">

        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <div class="mb-4 d-flex justify-content-between align-items-center">
                <p class="text-muted mb-0">
                    Resultados para: <strong class="text-dark">"@searchTerm"</strong>
                </p>
                <a asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-secondary">Limpar Filtro</a>
            </div>
        }

        <div class="row g-4">
            @if (Model.Products != null && Model.Products.Any())
            {
                @foreach (var product in Model.Products)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <div class="product-card h-100 shadow-sm d-flex flex-column justify-content-between p-3 bg-white rounded">
                            <div class="product-image-box text-center">
                                @if (!string.IsNullOrEmpty(product.CoverImageUrl))
                                {
                                    <img src="@product.CoverImageUrl" alt="@product.Name" class="img-fluid rounded" style="max-height: 180px; object-fit: cover;">
                                }
                                else
                                {
                                    <div class="py-4 bg-light text-muted rounded"><h5>Sem Imagem</h5></div>
                                }
                                <div class="fw-bold my-2 text-dark">@product.Name</div>
                                <div class="product-price text-success fw-bold">R$ @product.Price</div>
                            </div>

                            <div class="mt-3">
                                <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm w-100">
                                    Ver Detalhes
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-search text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted fs-5 mt-3">Nenhum produto corresponde à sua busca.</p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-danger mt-2">Ver todo o cardápio</a>
                </div>
            }
        </div>
    </div>
</div>