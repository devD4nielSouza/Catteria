@model ProductListViewModel

@{
    ViewData["Title"] = "Cardápio";
}

<div class="cat-menu-hero py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-5 fw-bold">Nosso Cardápio</h1>
        <p class="lead mb-0">
            Cafés, doces, salgados e muito carinho em cada pedido.
        </p>
    </div>
</div>

<div class="container">

    <form asp-action="Index" method="get" class="mb-5">

        <div class="row justify-content-center">

            <div class="col-lg-5 col-md-7">

                <select class="form-select cat-filter"
                        name="SelectedCategoryById"
                        onchange="this.form.submit()">

                    <option value="">Todas as categorias</option>

                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryById == category.Id)
                        {
                            <option value="@category.Id" selected>
                                @category.Name
                            </option>
                        }
                        else
                        {
                            <option value="@category.Id">
                                @category.Name
                            </option>
                        }
                    }

                </select>

            </div>

        </div>

    </form>

    <div class="row g-4">

        @if (Model.Products.Any())
        {
            @foreach (var product in Model.Products)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">

                    <div class="card cat-card shadow-sm h-100">

                        <div class="cat-image">

                            @if (!string.IsNullOrEmpty(product.CoverImageUrl))
                            {
                                <img src="@product.CoverImageUrl"
                                     alt="@product.Name">
                            }
                            else
                            {
                                <div class="cat-no-image">
                                    Sem imagem
                                </div>
                            }

                        </div>

                        <div class="card-body d-flex flex-column">

                            <h5 class="fw-bold">
                                @product.Name
                            </h5>

                            @if (!string.IsNullOrWhiteSpace(product.Description))
                            {
                                <p class="text-muted cat-description">
                                    @product.Description
                                </p>
                            }

                            <div class="mt-auto">

                                <div class="d-flex justify-content-between align-items-center">

                                    <span class="cat-price">
                                        R$ @product.Price.ToString("N2")
                                    </span>

                                    <a asp-action="Details"
                                       asp-route-id="@product.Id"
                                       class="btn btn-primary rounded-pill">

                                        Ver detalhes

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="col-12">

                <div class="alert alert-warning text-center">

                    Nenhum produto encontrado.

                </div>

            </div>
        }

    </div>
    <br />
    <br />
    <br />
</div>