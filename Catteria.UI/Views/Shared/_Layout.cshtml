<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Catteria</title>

    <meta name="description" content="Catteria - Plataforma para amantes de gatos" />

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Fonte -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/home.css" />



    <style>
            body {
                background: #fdf7f2;
                font-family: 'Inter', sans-serif;
                color: #4e4e4e;
            }

            .navbar-catteria {
                background-color: #ffffff;
                border-bottom: 1px solid #f1e6dc;
            }

            .btn-catteria-primary {
                background-color: #4c78b2;
                color: white;
                border: none;
            }

                .btn-catteria-primary:hover {
                    background-color: #3b5e8c;
                    color: white;
                }

            .btn-catteria-secondary {
                background-color: #a4bcdf;
                color: #2c3e50;
                border: none;
            }

                .btn-catteria-secondary:hover {
                    background-color: #8faad4;
                }

            .cat-badge {
                background-color: #f1e6dc;
                color: #8c6d53;
                font-size: 0.85rem;
                font-weight: 600;
                padding: 0.4rem 1rem;
                border-radius: 50px;
            }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-catteria px-3 py-3 shadow-sm">
        <div class="container">

            <a class="navbar-brand fw-bold d-flex align-items-center gap-2"
                   asp-controller="Home"
                   asp-action="Index">
                <i class="bi bi-cat fs-4" style="color:#4c78b2;"></i>
                Catteria
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">

                <ul class="navbar-nav align-items-center gap-2">

                    <li class="nav-item">
                        <a class="btn btn-outline-secondary btn-sm"
                               asp-controller="Home"
                               asp-action="Index">
                            Home
                        </a>
                    </li>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm"
                                       asp-controller="Admin"
                                       asp-action="Index">
                                    Admin
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <span class="nav-link">
                                <i class="bi bi-person-circle"></i> @User.Identity.Name
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Account"
                                  asp-action="Logout"
                                  method="post"
                                  class="d-inline">

                                <button class="btn btn-outline-danger btn-sm">
                                    Sair
                                </button>

                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-primary btn-sm"
                                   asp-controller="Account"
                                   asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-warning btn-sm"
                                   asp-controller="Account"
                                   asp-action="Register">
                                Registrar
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <!-- CONTEÚDO -->
    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>