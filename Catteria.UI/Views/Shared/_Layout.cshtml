<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Catteria"] - Catteria</title>

    <meta name="description" content="Catteria - Plataforma para amantes de gatos" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="~/js/cart.js"></script>
    <link rel="stylesheet" href="~/css/Site.css" />
    <link rel="stylesheet" href="~/css/Home.css" />
    <link rel="stylesheet" href="~/css/Layout.css" />
    <link rel="stylesheet" href="~/css/Menu.css" />




</head>
<body>

    <div class="top-bar">
        <div class="container d-flex justify-content-between align-items-center">
            <div>Bem-vindo, faça seu login ou cadastre-se!</div>
            <img class="whatsapp-icon" src="~/Imagens/whatsapp.png" />
            <div> (11) 999-999-8888</div>
        </div>
    </div>

    <div class="navbar-custom shadow-sm">
        <div class="container d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-3 w-100">
                <a asp-controller="Home" asp-action="Index">
                    <img class="logoImg" src="~/Imagens/logo1.png" alt="Logo Catteria">
                    </a>

                    <form asp-controller="Products" asp-action="Index" method="get" class="d-flex flex-grow-1 mx-md-4" style="max-width: 500px;">
                        <div class="input-group d-flex">
                            <input type="text"
                                   name="search"
                                   class="form-control search-bar"
                                   placeholder="Busque aqui"
                                   value="@Context.Request.Query["search"]">

                            <button class="btn" style="background-color: var(--azul-escuro); color: white; border: none; border-radius: 0 20px 20px 0;" type="submit">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>

                    <div class="nav-links ms-auto d-none d-md-flex align-items-center">
                        <a asp-controller="Home" asp-action="Index">Home</a>
                        <a asp-controller="Products" asp-action="Index">Cardápio</a>
                    <a asp-controller="Home" asp-action="Index" asp-fragment="sobre-nos">Sobre</a>
                    
                        <a asp-controller="Cart" asp-action="Index" class="position-relative">

                            <i class="bi bi-cart3 fs-4"></i>

                            <span id="cart-count"
                                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                0
                            </span>

                        </a>


                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" style="color: var(--azul-escuro);">Admin</a>
                            }
                            <span class="ms-2 text-truncate" style="max-width: 100px; font-weight: bold;"><i class="bi bi-person-circle"></i> @User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline ms-2">
                            <button class="btn btn-sair btn-sm py-0 px-2" style="font-weight:bold;">Sair</button>
                        </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login">Login</a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-sm py-1 ms-2" style="background-color: var(--azul-escuro); color: white;">Registrar</a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <main>
            @RenderBody()
        </main>

        <footer class="footer-custom pt-5 pb-3">
            <div class="container">
                <div class="row text-center text-md-start">

                    <div class="col-md-4 text-center mb-4 mb-md-0">
                        <div class="mb-2">
                            <i class="bi bi-cat fs-1" style="color: var(--azul-escuro);"></i>
                        </div>
                        <h4 class="fw-bold" style="font-family: 'Comic Sans MS', cursive, sans-serif;">CATTERIA</h4>
                        <div class="d-flex justify-content-center gap-3 mt-3">
                            <a href="https://instagram.com" target="_blank" class="fs-4"><i class="bi bi-instagram"></i></a>
                            <a href="https://facebook.com" target="_blank" class="fs-4"><i class="bi bi-facebook"></i></a>
                            <a href="https://whatsapp.com" target="_blank" class="fs-4"><i class="bi bi-whatsapp"></i></a>
                        </div>
                    </div>

                    <div class="col-md-4 mb-4 mb-md-0">
                        <h5 class="fw-bold mb-3">A Empresa</h5>
                        <ul class="list-unstyled d-flex flex-column gap-2">
                            <li><a asp-controller="Home" asp-action="Sobre"><i class="bi bi-geo-alt-fill me-1"></i> Localização</a></li>
                            <li><a asp-controller="Home" asp-action="Sobre"><i class="bi bi-clock-fill me-1"></i> Horário de Funcionamento</a></li>
                            <li><a asp-controller="Home" asp-action="Felinos"><i class="bi bi-heart-fill me-1"></i> Nossos Felinos</a></li>
                        </ul>
                    </div>

                    <div class="col-md-4">
                        <h5 class="fw-bold mb-3">Peça Agora</h5>
                        <ul class="list-unstyled d-flex flex-column gap-2 mb-4">
                            <li><a asp-controller="Products" asp-action="Index"><i class="bi bi-journal-text me-1"></i> Ver Cardápio</a></li>
                            <li><a href="https://www.ifood.com.br" target="_blank"><i class="bi bi-bag-dash-fill me-1"></i> iFood</a></li>
                        </ul>

                        <h5 class="fw-bold mb-2">Suporte</h5>
                        <ul class="list-unstyled">
                            <li><a asp-controller="Home" asp-action="Contato"><i class="bi bi-envelope-fill me-1"></i> Fale Conosco</a></li>
                        </ul>
                    </div>

                </div>

                <hr class="my-4" style="border-color: rgba(0,0,0,0.1);">

                <div class="text-center copyright-bar py-2 rounded">
                    © 2026 - Criado e Desenvolvido por: Graziella Santos Silva-Tl31
                </div>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script></body>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    </html>