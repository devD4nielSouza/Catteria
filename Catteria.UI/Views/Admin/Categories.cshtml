@model IEnumerable<Catteria.Application.DTOs.CategoryDto>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Categorias";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="page-title mb-1">
                Gerenciar Categorias
            </h2>

            <p class="page-subtitle mb-0">
                Cadastre, edite e remova as categorias dos produtos da Catteria.
            </p>
        </div>

        <a asp-action="CreateCategory" class="btn btn-primary-senac">
            <i class="bi bi-plus-circle me-1"></i>
            Nova Categoria
        </a>

    </div>

    <div class="admin-card">

        <div class="table-responsive">

            <div class="table-senac">

                <table class="table table-hover align-middle mb-0">

                    <thead>
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>Categoria</th>
                            <th style="width:150px;">Produtos</th>
                            <th class="text-end" style="width:180px;">Ações</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (Model.Any())
                        {
                            @foreach (var category in Model)
                            {
                                <tr>

                                    <td class="text-muted fw-semibold">
                                        #@category.Id
                                    </td>

                                    <td>
                                        <strong>@category.Name</strong>
                                    </td>

                                    <td>
                                        <span class="badge">
                                            @category.ProductCount Produto(s)
                                        </span>
                                    </td>

                                    <td class="text-end">

                                        <a asp-action="UpdateCategory"
                                               asp-route-id="@category.Id"
                                               class="btn btn-sm btn-outline-primary me-2"
                                               title="Editar">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="DeleteCategory"
                                               asp-route-id="@category.Id"
                                               class="btn btn-sm btn-outline-danger"
                                               title="Excluir">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="4" class="text-center py-5">

                                    <i class="bi bi-folder2-open fs-1 d-block mb-3 text-secondary"></i>

                                    <h5 class="mb-2">
                                        Nenhuma categoria encontrada
                                    </h5>

                                    <p class="text-muted mb-4">
                                        Comece cadastrando sua primeira categoria.
                                    </p>

                                    <a asp-action="CreateCategory"
                                           class="btn btn-primary-senac">

                                        <i class="bi bi-plus-circle me-1"></i>

                                        Nova Categoria

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>