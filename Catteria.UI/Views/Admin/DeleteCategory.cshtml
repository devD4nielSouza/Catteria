@model CategoryDto

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Excluir Categoria";
}

<div class="container-fluid">

    <div class="mb-4">

        <h2 class="page-title mb-1">
            Excluir Categoria
        </h2>

        <p class="page-subtitle mb-0">
            Confirme a exclusão da categoria selecionada.
        </p>

    </div>

    <div class="row justify-content-center">

        <div class="col-lg-6 col-md-8">

            <div class="admin-card text-center">

                <div class="mb-4">
                    <i class="bi bi-exclamation-triangle-fill text-danger"
                       style="font-size: 4rem;"></i>

                    <h3 class="mt-3 mb-2">
                        Confirmar Exclusão
                    </h3>

                    <p class="page-subtitle mb-0">
                        Tem certeza de que deseja excluir esta categoria?
                    </p>
                </div>

                <div class="rounded-4 border p-4 mb-4 bg-light">

                    <h4 class="mb-2">
                        @Model.Name
                    </h4>

                    <span class="badge">
                        @Model.ProductCount Produto(s)
                    </span>

                </div>

                @if (Model.ProductCount > 0)
                {
                    <div class="alert alert-warning mb-4">

                        <i class="bi bi-exclamation-circle-fill me-2"></i>

                        Esta categoria possui produtos associados e não pode ser excluída.

                    </div>
                }

                <div class="d-flex justify-content-center gap-3">

                    <a asp-action="Categories"
                           class="btn btn-outline-secondary">

                        <i class="bi bi-arrow-left me-1"></i>

                        Cancelar

                    </a>

                    <form asp-action="DeleteCategoryConfirmed"
                          asp-route-id="@Model.Id"
                          method="post">

                        <button type="submit"
                                class="btn btn-outline-danger"
                            @(Model.ProductCount > 0 ? "disabled" : "")>

                            <i class="bi bi-trash me-1"></i>

                            Excluir Categoria

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>