@* Home — Catteria (Style Epic) *@

@{
    ViewData["Title"] = "Home - Catteria";
    Layout = null; // Tela cheia customizada para a Home
}

<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/site.css" />
    
    <style>
        body {
            background: #fdf7f2;
            font-family: 'Inter', sans-serif;
            color: #4e4e4e;
        }
        .navbar-catteria {
            background-color: #ffffff;
            border-bottom: 1px solid #f1e6dc;
        }
        .btn-catteria-primary {
            background-color: #4c78b2;
            color: white;
            border: none;
        }
        .btn-catteria-primary:hover {
            background-color: #3b5e8c;
            color: white;
        }
        .btn-catteria-secondary {
            background-color: #a4bcdf;
            color: #2c3e50;
            border: none;
        }
        .btn-catteria-secondary:hover {
            background-color: #8faad4;
            color: #2c3e50;
        }
        .hero-section {
            min-height: calc(100vh - 80px);
        }
        .cat-badge {
            background-color: #f1e6dc;
            color: #8c6d53;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            display: inline-block;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-catteria px-4 py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center fw-bold" asp-controller="Home" asp-action="Index" style="color: #4e4e4e;">
                <i class="bi bi-cat me-2" style="color: #4c78b2; font-size: 1.5rem;"></i>
                <span>Catteria</span>
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <div class="d-flex gap-2 mt-3 mt-lg-0">
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary px-4 py-2" style="border-color: #4c78b2; color: #4c78b2;">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Entrar
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-catteria-primary px-4 py-2">
                        <i class="bi bi-person-plus me-1"></i> Criar Conta
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <main class="container hero-section d-flex align-items-center">
        <div class="row align-items-center g-5 w-100m m-0">
            
            <div class="col-12 col-lg-6 text-center text-lg-start">
                <div class="cat-badge mb-3">
                    <i class="bi bi-heart-fill me-1"></i> O paraíso dos apaixonados por gatos
                </div>
                <h1 class="display-4 fw-bold mb-3" style="color: #4e4e4e;">
                    Bem-vindo à <span style="color: #4c78b2;">Catteria</span>
                </h1>
                <p class="lead mb-4 text-muted">
                    Conecte-se com outros tutores, acompanhe a rotina do seu felino, agende consultas e encontre tudo o que seu melhor amigo precisa em um só lugar.
                </p>
                <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center justify-content-lg-start">
                    <a asp-controller="Account" asp-action="Register" class="btn btn-catteria-primary btn-lg px-5 py-3 shadow-sm">
                        Cadastre-se Agora
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-catteria-secondary btn-lg px-5 py-3 shadow-sm">
                        Já tenho cadastro
                    </a>
                </div>
            </div>

            <div class="col-12 col-lg-6 text-center d-none d-lg-block">
                <img src="/imgs/catlogin.png" alt="Catteria Cat" class="img-fluid" style="max-height: 450px; object-fit: contain;" />
            </div>

        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>