@model HomeViewModel
@{
	ViewData["Title"] = "Home";
}

<div class="top-bar">
	<div class="container d-flex justify-content-between align-items-center">
		<div>Bem-vindo, faça seu login ou cadastre-se!</div>

		<!-- Agrupamos o ícone e o número aqui -->
		<div class="d-flex align-items-center gap-2">
			<img class="whatsapp-icon" src="~/imagens/whatsapp.png" alt="WhatsApp" />
			<div class="header2">(11) 999-999-8888</div>
		</div>
	</div>
</div>

<div class="navbar-custom">
	<div class="container d-flex align-items-center justify-content-between">
		<div class="d-flex align-items-center gap-3 w-100">
			<div>
				<img class="logoImg" src="~/imagens/logo1.png" alt="Logo Catteria">
			</div>
			<input type="text" class="search-bar" placeholder="Busca">
			<div class="nav-links ms-auto d-none d-md-block">
				<a href="#">Home</a>
				<a href="#">Cardápio</a>
				<a href="#">Sobre</a>
				<a href="#">Conta</a>
				<a href="#">Carrinho</a>
			</div>
			<div class="nav-icons ms-md-3">
				<span></span>
				<span></span>
				<span></span>
			</div>
		</div>
	</div>
</div>

<div>
	<img class="Banner w-100" src="~/imagens/banner1.png" alt="Banner Principal">
</div>

<div class="section-title-bar">
	Cardápio
</div>

<div class="products-section">
	<div class="container">
		<div class="row">
			@foreach (var product in Model.FeaturedProducts.Take(3))
			{
				<div class="col-md-4 col-sm-6 mb-4">
					<a asp-controller="Products"
					   asp-action="Details"
					   asp-route-id="@product.Id"
					   class="text-decoration-none">

						<div class="product-card h-100">

							<div class="product-image-box">
								@if (!string.IsNullOrEmpty(product.CoverImageUrl))
								{
									<img src="@product.CoverImageUrl"
										 alt="@product.Name"
										 class="img-fluid" />
								}
								else
								{
									<img src="~/Imagens/"
										 alt="Imagem não disponível"
										 class="img-fluid" />
								}
							</div>

							<div class="p-3 text-center">
								<h5 class="fw-bold mb-2 text-dark">
									@product.Name
								</h5>

								<div class="product-price">
									R$ @product.Price.ToString("N2")
								</div>
							</div>

						</div>
					</a>
				</div>
			}

			<div class="col-12 text-center mt-3">
				<a asp-controller="Products"
				   asp-action="Index"
				   class="btn-veja-tudo">
					Veja tudo
				</a>
			</div>
		</div>

		<div class="wave-divider">
			<div class="wave-scallop"></div>
			<div class="hearts-row"></div>
		</div>

		<div class="about-section">
			<div class="row align-items-center">
				<div class="col-md-4 text-center mb-4 mb-md-0">
					<div class="about-facade-box mx-auto" style="max-width: 260px;">
						<div class="facade-roof"></div>
						<div style="font-size: 4rem;"></div>
						<img class="fachadaImg img-fluid" src="~/imagens/faixada.png" alt="Fachada da loja">
					</div>
				</div>
				<div class="col-md-8">
					<h2 class="fw-bold mb-3" style="font-family: 'Comic Sans MS', cursive, sans-serif;">Sobre nós</h2>
					<p style="text-align: justify; line-height: 1.6;">
						Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut
						labore et dolore magna aliqua. Quis ipsum suspendisse ultrices gravida. Risus commodo viverra
						maecenas accumsan lacus vel facilisis.
					</p>
					<p style="text-align: justify; line-height: 1.6;">
						Venha se apaixonar pelo primeiro espaço temático planejado inteiramente para os amantes de café
						e felinos. Nossos produtos são produzidos diariamente com todo o carinho que você merece.
					</p>
				</div>
			</div>
		</div>
	</div>
</div>

<footer class="footer-custom">
	<div class="container">
		<div class="row text-center text-md-start">
			<div class="col-md-4 text-center mb-4 mb-md-0">
				<div>
					<img class="logoImg" src="~/imagens/logo2.png" alt="Logo Footer">
				</div>
				<h4 class="fw-bold" style="font-family: 'Comic Sans MS';">CATTERIA</h4>
				<div class="footer-socials mt-2">
					<span></span><span></span><span></span>
				</div>
			</div>
			<div class="col-md-4 mb-4 mb-md-0">
				<h5>A empresa</h5>
				<ul>
					<li>Localização</li>
					<li>Horário de funcionamento</li>
					<li>Nossos Felinos</li>
				</ul>
			</div>
			<div class="col-md-4">
				<h5>Contatos</h5>
				<ul class="mb-3">
					<li>Telefone / WhatsApp</li>
					<li>Instagram</li>
					<li>Facebook</li>
				</ul>
				<h5>Peça Agora</h5>
				<ul>
					<li>iFood</li>
					<li>Avalie-nos</li>
				</ul>
			</div>
		</div>
	</div>
</footer>

<div class="copyright-bar text-center py-3">
	© 2026 - Criado e Desenvolvido por: Graziella Santos Silva-Tl31
</div>